# Stellar network: TESTNET or PUBLIC
NEXT_PUBLIC_STELLAR_NETWORK=TESTNET

# Per-network bridge contract addresses
NEXT_PUBLIC_BRIDGE_CONTRACT_ID_TESTNET=
NEXT_PUBLIC_BRIDGE_CONTRACT_ID_MAINNET=
NEXT_PUBLIC_BRIDGE_CONTRACT_ID_FUTURENET=

# Legacy single-network bridge contract (fallback, deprecated in favour of per-network vars above)
NEXT_PUBLIC_BRIDGE_CONTRACT_ID=

# Fiat onramp provider API keys
NEXT_PUBLIC_MOONPAY_API_KEY=
NEXT_PUBLIC_TRANSAK_API_KEY=

# Contract admin page (set to "true" to enable /contracts)
NEXT_PUBLIC_CONTRACTS_ADMIN=

# Enable mock data for local development (no Freighter or live network required)
NEXT_PUBLIC_DEV_MOCK=false
